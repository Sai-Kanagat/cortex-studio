# Copy to .env and fill in. Nothing here is required to run the mock path.

# --- LLM ---
# "mock" runs the whole graph offline (deterministic, no key).
# "gemini" = free tier, get a key at https://aistudio.google.com (no card needed).
# "anthropic" = Claude.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model tiers auto-default per provider (Gemini: flash-lite/flash/pro; Claude: haiku/sonnet/opus).
# Only set these to override the defaults.
MODEL_CHEAP=
MODEL_MID=
MODEL_HEAVY=

# --- Infra (docker-compose overrides these for the api container) ---
DATABASE_URL=postgresql://cortex:cortex@localhost:5432/cortex
REDIS_URL=redis://localhost:6379/0

# --- Observability (M4) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- Security ---
# Leave empty to disable API auth locally. Set to require an X-API-Key header.
CORTEX_API_KEY=

# --- Agent behaviour ---
MAX_CRITIC_LOOPS=2
