# Copy to .env and fill in. Nothing here is required to run the mock path.

# --- LLM ---
# "mock" runs the whole graph offline (deterministic, no key). Switch to "anthropic" for real runs.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=

# Model tiers (defaults match current Claude ids; update from the claude-api skill).
MODEL_CHEAP=claude-haiku-4-5-20251001
MODEL_MID=claude-sonnet-5
MODEL_HEAVY=claude-opus-4-8

# --- Infra (docker-compose overrides these for the api container) ---
DATABASE_URL=postgresql://cortex:cortex@localhost:5432/cortex
REDIS_URL=redis://localhost:6379/0

# --- Observability (M4) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- Security ---
# Leave empty to disable API auth locally. Set to require an X-API-Key header.
CORTEX_API_KEY=

# --- Agent behaviour ---
MAX_CRITIC_LOOPS=2
